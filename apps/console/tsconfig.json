{
  "extends": "@planisfy/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@planisfy/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@planisfy/auth": [
        "../../packages/auth/src/index.ts"
      ],
      "@planisfy/auth/*": [
        "../../packages/auth/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
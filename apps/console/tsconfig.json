{
  "extends": "@planisfy/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"],
      "@planisfy/ui/*": ["../../packages/ui/src/*"],
      "@planisfy/auth/client": ["../../packages/auth/src/client/index.ts"],
      "@planisfy/auth/server": ["../../packages/auth/src/server/index.ts"],
      "@planisfy/auth/ui": ["../../packages/auth/src/ui.tsx"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}

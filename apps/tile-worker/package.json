    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@planisfy/eslint-config": "workspace:*",
    "@planisfy/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "eslint": "^9.39.2",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  }

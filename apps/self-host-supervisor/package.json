{
  "name": "self-host-supervisor",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "node ../../packages/eslint-config/node_modules/eslint/bin/eslint.js . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@hono/node-server": "^1.14.1",
    "@planisfy/upgrade-manifest": "workspace:*",
    "dotenv": "^16.4.7",
    "hono": "^4.7.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@planisfy/eslint-config": "workspace:*",
    "@planisfy/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "5.9.2"
  }
}

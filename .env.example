# Database
DATABASE_URL="postgresql://planisfy:planisfy@localhost:5432/planisfy"

# Auth (better-auth)
BETTER_AUTH_SECRET=""
INTERNAL_API_SECRET=""
GITHUB_CLIENT_ID="replace-me-github-client-id"
GITHUB_CLIENT_SECRET="replace-me-github-client-secret"
GOOGLE_CLIENT_ID="replace-me-google-client-id"
GOOGLE_CLIENT_SECRET="replace-me-google-client-secret"
# Optional public callback origin for local OAuth through a tunnel.
# The auth handler lives at /api/auth under this origin.
OAUTH_PROXY_ORIGIN="https://api-dev.planisfy.com"
# Comma-separated list rendered in auth UI after real OAuth credentials are set.
NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS="google"
# Optional base64: 32-byte key for source credential encryption.
# Falls back to BETTER_AUTH_SECRET/INTERNAL_API_SECRET for local development.
SOURCE_CREDENTIAL_ENCRYPTION_KEY=""
ALLOW_PRIVATE_SOURCE_URLS=false

# API server
PORT=4000
NODE_ENV=development
APP_VERSION=dev
# Official v1 deployment modes: self_host or managed.
# self_host keeps billing/email/storage optional; managed requires Dodo, ZeptoMail, and R2.
DEPLOYMENT_MODE=self_host

# Local dev Cloudflare Tunnel for forwarding external payment webhooks to the API.
# Create a named Cloudflare Tunnel route for this hostname, then run:
#   pnpm --filter tunnel dev
CLOUDFLARED_BIN="cloudflared"
CLOUDFLARE_TUNNEL_NAME="planisfy-api-dev"
CLOUDFLARE_TUNNEL_PUBLIC_URL="https://api-dev.planisfy.com"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# Geospatial services
MARTIN_URL="http://localhost:3005"
# api serves published PMTiles directly. worker proxies tile/tilequery reads to
# apps/tile-worker; run Compose with --profile with-tile-worker when enabled.
TILE_DELIVERY_MODE=api
TILE_WORKER_URL="http://tile-worker:4020"
VALHALLA_URL="http://localhost:3007"
PELIAS_URL="http://localhost:3100"
# Use http://pelias:4000 when running the bundled Compose stack.
# Use http://host.docker.internal:3100 when Pelias runs outside Compose.
CONTAINER_PELIAS_URL="http://pelias:4000"
PELIAS_API_IMAGE="pelias/api:v7.8.0"
PELIAS_ELASTICSEARCH_IMAGE="pelias/elasticsearch:7.17.27-2025-01-22-66b2b704398cecb3f0bccede4286a840972c57f8"
PELIAS_SCHEMA_IMAGE="pelias/schema:v9.1.0"
PELIAS_CSV_IMPORTER_IMAGE="pelias/csv-importer:v5.4.0"
PELIAS_ES_JAVA_OPTS="-Xms2g -Xmx2g"
GLYPHS_URL="https://demotiles.maplibre.org/font"
ELEVATION_URL="https://api.open-elevation.com/api/v1"
STATIC_MAP_URL=""
# Optional self-host demo PMTiles fixture. Keep downloaded map data out of Git.
DEMO_PMTILES_PATH="/data/pmtiles/stuttgart.pmtiles"
# PLANISFY_FIXTURE_BASE_URL points at the public fixture prefix, for example:
# https://pub-<account>.r2.dev/v1 or https://fixtures.example.com/v1
PLANISFY_FIXTURE_BASE_URL="https://pub-61ad6d8b2ab1446f9265de304694e404.r2.dev/v1"
# DEMO_PMTILES_URL defaults to $PLANISFY_FIXTURE_BASE_URL/pmtiles/stuttgart.pmtiles.
# DEMO_PMTILES_URL=
# DEMO_PMTILES_SHA256=
# DEMO_PMTILES_FALLBACK_URL=
# DEMO_PMTILES_FALLBACK_PATH=

# Storage (s3, r2, or local). Self-host defaults to local MinIO via the
# Compose with-minio profile. Local filesystem storage is a demo/dev fallback.
STORAGE_PROVIDER=s3
LOCAL_STORAGE_PATH=".storage"
# Relative to infra/docker/docker-compose.yml so Docker Desktop can translate
# the WSL bind mount correctly.
LOCAL_STORAGE_HOST_PATH="../../.storage"
LOCAL_STORAGE_URL="https://api.planisfy.localhost/storage"
LOCAL_STORAGE_BUCKET="planisfy-local"
S3_BUCKET="planisfy-artifacts"
S3_REGION="auto"
S3_ENDPOINT="http://localhost:9000"
CONTAINER_S3_ENDPOINT="http://minio:9000"
AWS_ACCESS_KEY_ID="planisfy"
AWS_SECRET_ACCESS_KEY="planisfy-local-minio-password"
S3_PUBLIC_URL="http://localhost:9000/planisfy-artifacts"
MINIO_ROOT_USER=planisfy
MINIO_ROOT_PASSWORD=planisfy-local-minio-password
# Local MinIO profile:
#   docker compose --env-file .env -f infra/docker/docker-compose.yml --profile with-minio up -d
# To force demo filesystem storage instead, set STORAGE_PROVIDER=local.
R2_ACCOUNT_ID=""
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_ENDPOINT=""
R2_PUBLIC_URL=""
# MARTIN_SOURCES_PREFIX="martin-sources"

# Worker
GEODATA_WORKER_CONCURRENCY=2
GEODATA_WORKER_HEARTBEAT_INTERVAL_MS=10000
GEODATA_WORKER_HEARTBEAT_TTL_MS=45000
GEODATA_OUTBOX_POLL_INTERVAL_MS=5000
GEODATA_OUTBOX_BATCH_SIZE=10
GEODATA_STALE_JOB_RECONCILE_INTERVAL_MS=60000
GEODATA_STALE_JOB_THRESHOLD_MS=3600000
# DuckDB-backed Overture import jobs. Set OVERTURE_RELEASE to enable extraction.
OVERTURE_ALLOW_EXPERIMENTAL_TYPES="false"
DUCKDB_PATH="duckdb"
TIPPECANOE_PATH="tippecanoe"
OGR2OGR_PATH="ogr2ogr"
GEODATA_ALLOW_RAW_FALLBACK="false"
OVERTURE_RELEASE=""
OVERTURE_PARQUET_URL_TEMPLATE="s3://overturemaps-us-west-2/release/{release}/theme={theme}/type={type}/*"
SOURCE_IMPORT_MAX_FEATURES=50000
SOURCE_IMPORT_TIMEOUT_MS=900000

# Billing (Dodo Payments). Required for DEPLOYMENT_MODE=managed; optional for self_host.
DODO_PAYMENTS_API_KEY=""
DODO_PAYMENTS_ENVIRONMENT="test_mode"
DODO_PAYMENTS_WEBHOOK_SECRET=""
DODO_PAYMENTS_BRAND_ID=""
DODO_STARTER_MONTHLY_PRODUCT_ID=""
DODO_STARTER_YEARLY_PRODUCT_ID=""
DODO_SCALE_MONTHLY_PRODUCT_ID=""
DODO_SCALE_YEARLY_PRODUCT_ID=""

# Email (ZeptoMail). Required for DEPLOYMENT_MODE=managed; optional/dry-run for self_host.
ZEPTOMAIL_SEND_MAIL_TOKEN=""
ZEPTOMAIL_FROM_AUTH=""
ZEPTOMAIL_FROM_NOTIFICATIONS=""

# Browser/public navigation
NEXT_PUBLIC_APP_URL="https://console.planisfy.localhost"
NEXT_PUBLIC_AUTH_ORIGIN="https://api.planisfy.localhost"
NEXT_PUBLIC_API_URL="https://api.planisfy.localhost"
# Internal server-to-server API origin for the Console container.
CONSOLE_API_INTERNAL_ORIGIN=""
NEXT_PUBLIC_ADMIN_URL="https://admin.planisfy.localhost"
NEXT_PUBLIC_CONSOLE_URL="https://console.planisfy.localhost"
NEXT_PUBLIC_DOCS_URL="https://docs.planisfy.localhost"
NEXT_PUBLIC_MARKETING_URL="https://planisfy.localhost"
NEXT_PUBLIC_CONTACT_EMAIL="support@planisfy.localhost"
NEXT_PUBLIC_CONSOLE_API_PATH="/api/v1/console"

# Local-only self-host upgrade supervisor. Disabled unless the Compose
# with-supervisor profile is started.
# SUPERVISOR_URL="http://self-host-supervisor:4010"
# SUPERVISOR_TOKEN="generate-a-random-supervisor-token-here"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://planisfy:planisfy@localhost:5432/planisfy"

# ── Auth (better-auth) ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="http://localhost:3001/api/auth"

# ── API Server ────────────────────────────────────────────────────────────────
PORT=4000

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── External Services ────────────────────────────────────────────────────────
MARTIN_URL="http://localhost:3005"
VALHALLA_URL="http://localhost:3007"
PELIAS_URL="http://localhost:4000"
NOMINATIM_URL="https://nominatim.openstreetmap.org"

# ── Storage (local or s3) ────────────────────────────────────────────────────
STORAGE_PROVIDER=local
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=

# ── Billing (Polar) ──────────────────────────────────────────────────────────
# POLAR_ACCESS_TOKEN=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=dev

# Database
DATABASE_URL="postgresql://planisfy:planisfy@localhost:5432/planisfy"

# Auth (better-auth)
BETTER_AUTH_SECRET="generate-a-random-secret-here"
BETTER_AUTH_URL="https://console.planisfy.localhost/api/auth"
INTERNAL_API_SECRET="generate-a-random-internal-secret-here"
INTERNAL_API_URL="https://api.planisfy.localhost"
# Optional base64: 32-byte key for source credential encryption.
# Falls back to BETTER_AUTH_SECRET/INTERNAL_API_SECRET for local development.
# SOURCE_CREDENTIAL_ENCRYPTION_KEY=
ALLOW_PRIVATE_SOURCE_URLS=false

# API server
PORT=4000
API_URL="https://api.planisfy.localhost"
CONSOLE_URL="https://console.planisfy.localhost"
NODE_ENV=development
APP_VERSION=dev

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST=localhost
REDIS_PORT=6379

# Geospatial services
MARTIN_URL="http://localhost:3005"
VALHALLA_URL="http://localhost:3007"
PELIAS_URL="https://api.planisfy.localhost/geocoding"
GLYPHS_URL="https://demotiles.maplibre.org/font"
ELEVATION_URL="https://api.open-elevation.com/api/v1"
# STATIC_MAP_URL=
# Optional self-host demo PMTiles fixture. Keep downloaded map data out of Git.
# DEMO_PMTILES_URL=
# DEMO_PMTILES_SHA256=

# Storage (local, s3, or r2). Docker Compose mounts infra/docker/data/storage at /data/storage.
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=".storage"
LOCAL_STORAGE_URL="https://api.planisfy.localhost/storage"
LOCAL_STORAGE_BUCKET="planisfy-local"
# S3_BUCKET="planisfy-uploads"
# S3_REGION="auto"
# S3_ENDPOINT=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL=
# R2_ACCOUNT_ID=
# R2_BUCKET="planisfy-artifacts"
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# R2_PUBLIC_URL="https://artifacts.example.com"
# MARTIN_SOURCES_PREFIX="martin-sources"

# Worker
GEODATA_WORKER_CONCURRENCY=2
GEODATA_WORKER_HEARTBEAT_INTERVAL_MS=10000
GEODATA_WORKER_HEARTBEAT_TTL_MS=45000
# DuckDB-backed Overture import jobs. Set OVERTURE_RELEASE to enable extraction.
OVERTURE_ALLOW_EXPERIMENTAL_TYPES="false"
DUCKDB_PATH="duckdb"
TIPPECANOE_PATH="tippecanoe"
OGR2OGR_PATH="ogr2ogr"
GEODATA_ALLOW_RAW_FALLBACK="false"
# OVERTURE_RELEASE=
OVERTURE_PARQUET_URL_TEMPLATE="s3://overturemaps-us-west-2/release/{release}/theme={theme}/type={type}/*"
SOURCE_IMPORT_MAX_FEATURES=50000
SOURCE_IMPORT_TIMEOUT_MS=900000

# Billing (Dodo Payments)
# DODO_PAYMENTS_API_KEY=
# DODO_PAYMENTS_API_URL=
DODO_PAYMENTS_ENVIRONMENT="test_mode"
# DODO_PAYMENTS_WEBHOOK_SECRET=
# DODO_PRO_PRODUCT_ID=
# DODO_ENTERPRISE_PRODUCT_ID=

# Email (Resend)
# RESEND_API_KEY=
FROM_EMAIL="Planisfy <noreply@planisfy.com>"

# Browser/public navigation
NEXT_PUBLIC_APP_URL="https://console.planisfy.localhost"
NEXT_PUBLIC_API_URL="https://api.planisfy.localhost"
NEXT_PUBLIC_ADMIN_URL="https://admin.planisfy.localhost"
NEXT_PUBLIC_CONSOLE_URL="https://console.planisfy.localhost"
NEXT_PUBLIC_MARKETING_URL="https://planisfy.localhost"
NEXT_PUBLIC_CONSOLE_API_PATH="/api/v1/console"

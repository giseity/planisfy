{
  "esclient": {
    "apiVersion": "7.17",
    "connections": 10,
    "indexPrefix": "pelias",
    "hosts": [
      { "host": "elasticsearch", "port": 9200 }
    ]
  },
  "elasticsearch": {
    "indexPrefix": "pelias",
    "settings": {
      "index": {
        "number_of_shards": 1,
        "number_of_replicas": 0
      }
    }
  },
  "api": {
    "version": "v1",
    "indexName": "pelias",
    "accessLog": {
      "enabled": true
    },
    "services": {
      "placeholder": {
        "disable": false
      },
      "libpostal": {
        "url": "http://libpostal:4400",
        "disabled": false
      },
      "pip": {
        "url": "http://pip:4002",
        "disabled": false,
        "localPipFiles": "/data/pip/local"
      },
      "whosonfirst": {
        "datapath": "/data/whosonfirst/data",
        "importPostalcodes": true
      },
      "openstreetmap": {
        "datapath": "/data/openstreetmap/data",
        "leveldbpath": "/data/openstreetmap/leveldb",
        "importFile": [
          "https://download.geofabrik.de/north-america-latest.osm.pbf"
        ]
      },
      "polyline": {
        "indexName": "pelias",
        "zoom": 12
      }
    },
    "autocomplete": {
      "search_size": 10
    }
  },
  "imports": {
    "adminLookup": {
      "enabled": true,
      "downloadDistributions": [
        "whosonfirst",
        "openstreetmap",
        "polyline"
      ]
    },
    "whosonfirst": {
      "datapath": "/data/whosonfirst/data",
      "importPostalcodes": true
    },
    "openstreetmap": {
      "datapath": "/data/openstreetmap/data",
      "leveldbpath": "/data/openstreetmap/leveldb",
      "importFile": [
        "https://download.geofabrik.de/north-america-latest.osm.pbf"
      ]
    }
  },
  "logger": {
    "level": "info",
    "timestamp": true
  }
}

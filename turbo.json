{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NODE_ENV",
        "HOST",
        "PORT",
        "NEXT_PHASE",
        "DATABASE_URL",
        "APP_VERSION",
        "DEPLOYMENT_MODE",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "BETTER_AUTH_BASE_URL",
        "INTERNAL_API_SECRET",
        "INTERNAL_API_URL",
        "API_URL",
        "CONSOLE_URL",
        "DUCKDB_PATH",
        "NEXT_PUBLIC_APP_URL",
        "RESEND_API_KEY",
        "DODO_PAYMENTS_API_KEY",
        "DODO_PAYMENTS_API_URL",
        "DODO_PAYMENTS_ENVIRONMENT",
        "DODO_PAYMENTS_WEBHOOK_SECRET",
        "DODO_PRO_PRODUCT_ID",
        "DODO_ENTERPRISE_PRODUCT_ID",
        "LOCAL_STORAGE_PATH",
        "LOCAL_STORAGE_BUCKET",
        "LOG_LEVEL",
        "MARTIN_SOURCES_PATH",
        "MARTIN_SOURCES_PREFIX",
        "OVERTURE_RELEASE",
        "OGR2OGR_PATH",
        "PLANISFY_RELEASE_MANIFEST",
        "PLANISFY_ROOT_DIR",
        "SOURCE_IMPORT_MAX_FEATURES",
        "SOURCE_IMPORT_TIMEOUT_MS",
        "STORAGE_PROVIDER",
        "SUPERVISOR_COMPOSE_FILE",
        "SUPERVISOR_ENV_FILE",
        "SUPERVISOR_STATE_DIR",
        "SUPERVISOR_TOKEN",
        "SUPERVISOR_URL",
        "TIPPECANOE_PATH",
        "DEMO_PMTILES_PATH",
        "S3_BUCKET",
        "R2_BUCKET",
        "R2_ENDPOINT",
        "R2_ACCOUNT_ID",
        "R2_PUBLIC_URL",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["CONTACT_EMAIL"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "docs#build": {
      "dependsOn": ["^build", "check-types"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NODE_ENV",
        "HOST",
        "PORT",
        "NEXT_PHASE",
        "DATABASE_URL",
        "APP_VERSION",
        "DEPLOYMENT_MODE",
        "BETTER_AUTH_SECRET",
        "AUTH_COOKIE_DOMAIN",
        "AUTH_INTERNAL_ORIGIN",
        "OAUTH_PROXY_ORIGIN",
        "INTERNAL_API_SECRET",
        "CONSOLE_API_INTERNAL_ORIGIN",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_CONSOLE_URL",
        "NEXT_PUBLIC_AUTH_ORIGIN",
        "NEXT_PUBLIC_AUTH_SOCIAL_PROVIDERS",
        "NEXT_PUBLIC_APP_URL",
        "NEXT_PUBLIC_ADMIN_URL",
        "NEXT_PUBLIC_MARKETING_URL",
        "NEXT_PUBLIC_CONSOLE_API_PATH",
        "CONTACT_EMAIL",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "DUCKDB_PATH",
        "RESEND_API_KEY",
        "DODO_PAYMENTS_API_KEY",
        "DODO_PAYMENTS_API_URL",
        "DODO_PAYMENTS_ENVIRONMENT",
        "DODO_PAYMENTS_WEBHOOK_SECRET",
        "DODO_STARTER_MONTHLY_PRODUCT_ID",
        "DODO_STARTER_YEARLY_PRODUCT_ID",
        "DODO_SCALE_MONTHLY_PRODUCT_ID",
        "DODO_SCALE_YEARLY_PRODUCT_ID",
        "DODO_PRO_PRODUCT_ID",
        "DODO_ENTERPRISE_PRODUCT_ID",
        "CLOUDFLARED_BIN",
        "CLOUDFLARE_TUNNEL_NAME",
        "CLOUDFLARE_TUNNEL_PUBLIC_URL",
        "LOCAL_STORAGE_PATH",
        "LOCAL_STORAGE_BUCKET",
        "LOG_LEVEL",
        "MARTIN_SOURCES_PATH",
        "MARTIN_SOURCES_PREFIX",
        "TILE_ALIAS_STORAGE_PREFIX",
        "PELIAS_URL",
        "CONTAINER_PELIAS_URL",
        "PELIAS_API_IMAGE",
        "PELIAS_ELASTICSEARCH_IMAGE",
        "PELIAS_SCHEMA_IMAGE",
        "PELIAS_CSV_IMPORTER_IMAGE",
        "PELIAS_ES_JAVA_OPTS",
        "VALHALLA_URL",
        "VALHALLA_READINESS_ROUTE",
        "OVERTURE_RELEASE",
        "OGR2OGR_PATH",
        "PLANISFY_RELEASE_MANIFEST",
        "PLANISFY_ROOT_DIR",
        "PROCESSING_ACTIVE_JOB_LIMIT",
        "SOURCE_IMPORT_MAX_FEATURES",
        "SOURCE_IMPORT_TIMEOUT_MS",
        "STORAGE_PROVIDER",
        "SUPERVISOR_COMPOSE_FILE",
        "SUPERVISOR_ENV_FILE",
        "SUPERVISOR_STATE_DIR",
        "SUPERVISOR_TOKEN",
        "SUPERVISOR_URL",
        "TIPPECANOE_PATH",
        "DEMO_PMTILES_PATH",
        "ELEVATION_DEM_DIR",
        "ELEVATION_URL",
        "S3_BUCKET",
        "GLYPHS_URL",
        "PLANISFY_API_URL",
        "STATIC_MAP_URL",
        "R2_BUCKET",
        "R2_ENDPOINT",
        "R2_ACCOUNT_ID",
        "R2_PUBLIC_URL",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY"
      ]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

{
  "name": "planisfy",
  "private": true,
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "turbo run build",
    "db:generate": "pnpm --filter @planisfy/database db:generate",
    "db:migrate": "pnpm --filter @planisfy/database db:migrate",
    "db:push": "pnpm --filter @planisfy/database db:push",
    "db:seed": "pnpm exec tsx scripts/dev-seed.ts",
    "db:studio": "pnpm --filter @planisfy/database db:studio",
    "dev": "turbo run dev",
    "dev:seed": "pnpm db:seed",
    "e2e:product-loop": "node scripts/product-loop-browser-smoke.mjs",
    "e2e:product-loop:full": "node scripts/product-loop-full-browser-smoke.mjs",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "fixtures:upload": "scripts/upload-public-fixtures.sh",
    "self-host:backup": "scripts/self-host-backup.sh",
    "self-host:restore": "scripts/self-host-restore.sh",
    "self-host:setup": "scripts/self-host-setup.sh",
    "self-host:support-bundle": "scripts/self-host-support-bundle.sh",
    "smoke:managed-local": "scripts/managed-local-smoke.sh",
    "smoke:managed-staging": "node scripts/managed-staging-smoke.mjs",
    "smoke:managed-staging-product-loop": "scripts/managed-staging-product-loop-smoke.sh",
    "smoke:self-host-backup-restore": "scripts/self-host-backup-restore-smoke.sh",
    "smoke:self-host-browser-map": "node scripts/self-host-browser-map-smoke.mjs",
    "smoke:self-host-compose": "scripts/docker-compose-smoke.sh",
    "smoke:self-host-default-map": "node scripts/self-host-default-map-smoke.mjs",
    "smoke:self-host-restart-persistence": "scripts/self-host-restart-persistence-smoke.sh",
    "smoke:self-host-route-protection": "scripts/self-host-route-protection-smoke.sh",
    "smoke:self-host-support-bundle": "scripts/self-host-support-bundle-smoke.sh",
    "smoke:self-host-upgrade": "node scripts/self-host-upgrade-smoke.mjs",
    "check-types": "turbo run check-types",
    "test": "turbo run test --concurrency=1",
    "verify": "turbo run lint check-types test build"
  },
  "devDependencies": {
    "@planisfy/eslint-config": "workspace:*",
    "@planisfy/typescript-config": "workspace:*",
    "portless": "^0.13.0",
    "prettier": "^3.7.4",
    "tsx": "^4.19.4",
    "turbo": "^2.8.3",
    "typescript": "5.9.2",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "engines": {
    "node": ">=24"
  }
}

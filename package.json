{
  "name": "planisfy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@planisfy/eslint-config": "workspace:*",
    "@planisfy/typescript-config": "workspace:*",
    "prettier": "^3.7.4",
    "turbo": "^2.8.3",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "overrides": {
      "esbuild": "^0.25.0"
    }
  },
  "engines": {
    "node": ">=18"
  }
}

{
  "name": "@planisfy/database",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./relations": "./src/relations/index.ts",
    "./styles/service": "./src/styles/service.ts",
    "./jobs/reconciliation": "./src/jobs/reconciliation.ts"
  },
  "scripts": {
    "lint": "node ../eslint-config/node_modules/eslint/bin/eslint.js . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@planisfy/env": "workspace:*",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@planisfy/eslint-config": "workspace:*",
    "@planisfy/typescript-config": "workspace:*",
    "@types/node": "^24.0.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "5.9.2"
  }
}

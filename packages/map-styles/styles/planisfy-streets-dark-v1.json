{
  "version": 8,
  "name": "Planisfy Streets Dark v1",
  "metadata": {
    "planisfy:styleId": "planisfy-streets-dark-v1",
    "planisfy:release": "planisfy-streets-v1.0.0",
    "planisfy:tileset": "planisfy-streets-v1",
    "mapbox:autocomposite": false,
    "mapbox:type": "template"
  },
  "glyphs": "{glyphsUrl}/{fontstack}/{range}.pbf",
  "sprite": "{spriteUrl}/planisfy-streets-v1",
  "sources": {
    "planisfy-streets": {
      "type": "vector",
      "url": "http://localhost:3005/planisfy.basic"
    }
  },
  "center": [9.1829, 48.7758],
  "zoom": 11,
  "bearing": 0,
  "pitch": 0,
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#14171a" }
    },
    {
      "id": "land",
      "type": "fill",
      "source": "planisfy-streets",
      "source-layer": "land",
      "paint": { "fill-color": "#1b1f23" }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "planisfy-streets",
      "source-layer": "landuse",
      "filter": ["in", ["get", "class"], ["literal", ["park", "wood", "grass", "recreation_ground"]]],
      "paint": {
        "fill-color": "#203628",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "planisfy-streets",
      "source-layer": "water",
      "paint": { "fill-color": "#163449" }
    },
    {
      "id": "admin-boundaries",
      "type": "line",
      "source": "planisfy-streets",
      "source-layer": "admin_boundary",
      "paint": {
        "line-color": "#56616d",
        "line-dasharray": [2, 2],
        "line-width": ["interpolate", ["linear"], ["zoom"], 0, 0.3, 8, 1.2]
      }
    },
    {
      "id": "roads-casing",
      "type": "line",
      "source": "planisfy-streets",
      "source-layer": "transportation",
      "filter": ["in", ["get", "class"], ["literal", ["motorway", "trunk", "primary", "secondary", "tertiary"]]],
      "paint": {
        "line-color": "#0f1114",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.9, 10, 2.2, 14, 7.5, 17, 18]
      }
    },
    {
      "id": "roads",
      "type": "line",
      "source": "planisfy-streets",
      "source-layer": "transportation",
      "paint": {
        "line-color": ["match", ["get", "class"], "motorway", "#d8894d", "trunk", "#ca9453", "primary", "#b7a264", "#39424a"],
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 10, 1.4, 14, 5, 17, 14]
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "planisfy-streets",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#2b3137",
        "fill-outline-color": "#3b444d",
        "fill-opacity": 0.9
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "planisfy-streets",
      "source-layer": "place",
      "layout": {
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 10, 14, 14, 18]
      },
      "paint": {
        "text-color": "#e9eef2",
        "text-halo-color": "#111417",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "road-labels",
      "type": "symbol",
      "source": "planisfy-streets",
      "source-layer": "transportation_name",
      "minzoom": 12,
      "layout": {
        "symbol-placement": "line",
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Regular"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#cbd3db",
        "text-halo-color": "#111417",
        "text-halo-width": 1
      }
    }
  ]
}

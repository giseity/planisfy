COMPOSE_PROJECT_NAME=planisfy-pelias-metro
DATA_DIR=./data
DOCKER_USER=1000:1000

# Keep this conservative for a 12GB WSL profile.
PELIAS_ES_HEAP=2g
OPENADDRESSES_PARALLELISM=1
CSV_PARALLELISM=1
ENABLE_GEONAMES=false

# Host ports. The API port avoids conflicts with Planisfy API :4000 and the
# tiny default fixture :3100.
PELIAS_METRO_API_PORT=34100
PELIAS_METRO_ES_PORT=34200
PELIAS_METRO_LIBPOSTAL_PORT=34400
PELIAS_METRO_PLACEHOLDER_PORT=34101
PELIAS_METRO_PIP_PORT=34201
PELIAS_METRO_INTERPOLATION_PORT=34300
ELASTIC_HOST=localhost:34200
ELASTIC_INDEX=pelias

# Pinned official Pelias service images.
PELIAS_API_IMAGE=pelias/api:v7.8.0
PELIAS_SCHEMA_IMAGE=pelias/schema:v9.1.0
PELIAS_PLACEHOLDER_IMAGE=pelias/placeholder:v5.5.0
PELIAS_LIBPOSTAL_IMAGE=pelias/libpostal-service:master-2023-07-04-b02f6f14cfe2dbf2dfee9e458a372f0aca13caa4
PELIAS_PIP_SERVICE_IMAGE=pelias/pip-service:v4.3.0
PELIAS_INTERPOLATION_IMAGE=pelias/interpolation:better-sqlite3-v2-plus-libpostal-service-2025-03-11-77f8209aadcd046312128f9b3fb37254c4081c84-classic
PELIAS_WOF_IMAGE=pelias/whosonfirst:v8.4.0
PELIAS_OPENSTREETMAP_IMAGE=pelias/openstreetmap:v8.4.2
PELIAS_OPENADDRESSES_IMAGE=pelias/openaddresses:v6.5.0
PELIAS_GEONAMES_IMAGE=pelias/geonames:v6.4.0
PELIAS_TRANSIT_IMAGE=pelias/transit:v5.4.0
PELIAS_CSV_IMPORTER_IMAGE=pelias/csv-importer:v5.4.0
PELIAS_POLYLINES_IMAGE=pelias/polylines:v5.3.0
PELIAS_FUZZY_TESTER_IMAGE=pelias/fuzzy-tester:v3.3.0
PELIAS_ELASTICSEARCH_IMAGE=pelias/elasticsearch:7.17.27-2025-01-22-66b2b704398cecb3f0bccede4286a840972c57f8
